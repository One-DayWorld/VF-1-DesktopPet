{
  "name": "vf-1-desktop-pet",
  "version": "1.0.0",
  "description": "VF-1 骷髅一号 桌面 AI 助手",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac --arm64 --x64"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "three": "^0.158.0"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.ace.vf1desktoppet",
    "productName": "VF-1 Desktop Pet",
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "VF-1 Desktop Pet",
      "icon": "build/icon.icns",
      "contents": [
        {
          "x": 130,
          "y": 220,
          "type": "file"
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "files": [
      "main.js",
      "panel.html",
      "pet.html",
      "preload.js",
      "store.js",
      "scripts/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "!node_modules/electron/**/*",
      "!node_modules/electron-builder/**/*",
      "!node_modules/.cache/**/*"
    ],
    "asar": true,
    "compression": "maximum"
  }
}
