{
  "name": "vf-1-desktop-pet",
  "version": "1.0.0",
  "description": "VF-1 骷髅一号 桌面 AI 助手",
  "license": "MIT",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac --arm64 --x64",
    "build:lite": "electron-builder --mac --arm64 --x64 -c.extraMetadata.vf1Lite=true -c.productName=\"VF-1 Lite\" -c.appId=com.ace.vf1desktoppetlite -c.dmg.title=\"VF-1 Lite\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "three": "^0.158.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.ace.vf1desktoppet",
    "productName": "Macross",
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "build/icon.icns",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "Macross",
      "icon": "build/icon.icns",
      "contents": [
        { "x": 130, "y": 220, "type": "file" },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ],
      "window": { "width": 540, "height": 380 }
    },
    "files": [
      "main.js",
      "panel.html",
      "pet.html",
      "preload.js",
      "store.js",
      "voice-lines.json",
      "scripts/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "!node_modules/electron/**/*",
      "!node_modules/electron-builder/**/*",
      "!node_modules/.cache/**/*"
    ],
    "asar": true,
    "compression": "maximum"
  }
}
